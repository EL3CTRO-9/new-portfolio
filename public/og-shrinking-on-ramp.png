<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <!-- bone background -->
  <rect width="1200" height="630" fill="#faf5f0"/>

  <!-- hairline frame -->
  <rect x="56" y="56" width="1088" height="518" fill="none" stroke="#1a1a1a" stroke-width="1.5" opacity="0.12"/>

  <!-- top row: category tag + date -->
  <g>
    <!-- SEC pill -->
    <rect x="80" y="96" width="62" height="30" fill="#ff2d1a"/>
    <text x="111" y="117" text-anchor="middle" font-family="JetBrains Mono" font-weight="700" font-size="15" letter-spacing="1" fill="#faf5f0">SEC</text>
    <!-- kicker -->
    <text x="158" y="117" font-family="JetBrains Mono" font-weight="500" font-size="15" letter-spacing="3" fill="#1a1a1a" opacity="0.55">ESSAY</text>
    <!-- date right -->
    <text x="1120" y="117" text-anchor="end" font-family="JetBrains Mono" font-weight="500" font-size="15" letter-spacing="2" fill="#1a1a1a" opacity="0.7">01 JUN 2026</text>
  </g>

  <!-- TITLE BLOCK : The Shrinking On-Ramp -->
  <text x="76" y="290" font-family="Bricolage Grotesque" font-weight="500" font-size="62" letter-spacing="-1" fill="#1a1a1a" opacity="0.65">The</text>
  <text x="76" y="392" font-family="Bricolage Grotesque" font-weight="800" font-size="112" letter-spacing="-3" fill="#1a1a1a">Shrinking</text>
  <text x="76" y="500" font-family="Bricolage Grotesque" font-weight="800" font-style="italic" font-size="112" letter-spacing="-3" fill="#ff2d1a" transform="skewX(-9)" transform-origin="76 500">On-Ramp</text>

  <!-- bottom rule + domain -->
  <line x1="80" y1="540" x2="1120" y2="540" stroke="#1a1a1a" stroke-width="1.5" opacity="0.15"/>
  <text x="80" y="558" font-family="JetBrains Mono" font-weight="500" font-size="15" letter-spacing="2" fill="#ff2d1a">sahilshaikh.in</text>

  <!-- SS monogram bottom-right -->
  <text x="1120" y="560" text-anchor="end" font-family="Bricolage Grotesque" font-weight="800" font-size="34" fill="#1a1a1a" opacity="0.5">SS</text>
</svg>
